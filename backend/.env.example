# Copy this file to .env and adjust as needed, or export these as real
# environment variables before running `npm start`. All have safe defaults
# for local demo use.

# HTTP server port (dashboard + REST API)
PORT=3000

# Embedded MQTT broker port (devices/simulators connect here)
MQTT_PORT=1883

# SQLite database file location
DB_PATH=./data/tower_platform.db

# Set to "false" to disable the built-in fleet simulator (e.g. once you're
# feeding the platform from real Wokwi devices / real hardware instead)
RUN_SIMULATOR=true
